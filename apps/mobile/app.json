{
  "expo": {
    "name": "Trano",
    "slug": "trano",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "mg.trano.app"
    },
    "android": {
      "package": "mg.trano.app",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Mampiasa ny toeranao i Trano mba hametrahana ny lisitranao eo amin'ny sarintany."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Mila fahazoan-dalana i Trano mba haka sary avy amin'ny tahirinao ho an'ny lisitranao."
        }
      ],
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "bc19ed78-6e57-4466-b99c-2e562fa29d64"
      }
    },
    "owner": "lovarakoto"
  }
}
